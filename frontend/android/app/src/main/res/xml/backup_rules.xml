<?xml version="1.0" encoding="utf-8"?>
<!--
    Backup rules for Android 11 and below (allowBackup=false means this is not used
    for cloud backup, but kept to suppress lint warnings and as documentation).
    WebView localStorage, cookies, and SharedPreferences (which may contain tokens)
    are explicitly excluded as a defence-in-depth measure.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="." />
    <exclude domain="database" path="." />
    <exclude domain="file" path="." />
    <exclude domain="external" path="." />
</full-backup-content>
