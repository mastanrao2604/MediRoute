# ─────────────────────────────────────────────────────────────────────────────
# keystore.properties — RELEASE SIGNING CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:  cp keystore.properties.example keystore.properties
# 2. Fill in the values below (keystore.properties is gitignored)
# 3. BACK UP your .jks file securely — if lost, Play Store updates are impossible
# ─────────────────────────────────────────────────────────────────────────────
#
# STEP 1 — Generate keystore (run once, keep the .jks file safe):
#
#   keytool -genkey -v \
#     -keystore mediroute-release.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 \
#     -alias mediroute \
#     -dname "CN=MediRoute, OU=Mobile, O=MediRoute Healthcare, L=Hyderabad, ST=Telangana, C=IN"
#
# STEP 2 — Get SHA-1 fingerprints (both needed for Google Cloud Console):
#
#   Debug SHA-1:
#     keytool -list -v -keystore "%USERPROFILE%\.android\debug.keystore" -alias androiddebugkey -storepass android -keypass android
#
#   Release SHA-1:
#     keytool -list -v -keystore mediroute-release.jks -alias mediroute
#
# STEP 3 — Add BOTH SHA-1s to Google Cloud Console:
#   → APIs & Services → Credentials → OAuth 2.0 Client IDs → Android client
#   → Also add https://localhost to Authorized JavaScript origins on the WEB client
#
# ─────────────────────────────────────────────────────────────────────────────
# Path is relative to the android/ folder (where build.gradle reads this file)
storeFile=../mediroute-release.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=mediroute
keyPassword=YOUR_KEY_PASSWORD
