# Copy to .env (local dev) or .env.production (Capacitor APK/release builds).
# These values are BAKED INTO the JS bundle at build time — no secrets here.

# ─── Backend API URL ──────────────────────────────────────────────────────────
# BAKED INTO THE APK AT BUILD TIME — VITE_API_URL decides which server receives OTP requests.
#
# DEV OTP (OTP in JSON as dev_otp, no MSG91): the backend must run with ENV=development
# AND this URL must point at THAT backend — NOT at Render/production.
#
# Typical setups:
#   • Production APK (MSG91 SMS): VITE_API_URL=https://your-app.onrender.com
#   • USB phone + PC uvicorn: build with scripts/build-android.ps1 -DevBackend (127.0.0.1 + adb reverse)
#   • Android emulator + PC uvicorn: VITE_API_URL=http://10.0.2.2:8000  OR  build-android.ps1 -ApiUrl http://10.0.2.2:8000
#
# Override without editing files: Vite honors process env — see build-android.ps1 -ApiUrl / -DevBackend.
# Optional: put overrides in frontend/.env.local (gitignored; wins over .env for most Vite modes).
#
# Local web dev (browser): http://localhost:8000
VITE_API_URL=http://localhost:8000

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Web client ID from Google Cloud Console → APIs & Services → Credentials
# Must match serverClientId in frontend/capacitor.config.json
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ─── Admin (non-secret) ───────────────────────────────────────────────────────
# Phone number that gets admin access. Admin SECRET is entered at runtime — not here.
VITE_ADMIN_PHONE=your_10_digit_phone

# ─── Sentry (optional — frontend error monitoring) ────────────────────────────
# VITE_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# ─── Debug logging (Capacitor / logcat) ───────────────────────────────────────
# When true: mlog + profile traces also emit console.debug → visible in adb logcat.
# Or enable at runtime on device: open app with ?debugLog=1 once, or WebView console:
#   localStorage.setItem('mediroute_debug_log','1'); location.reload()
# VITE_DEBUG_LOG=true
