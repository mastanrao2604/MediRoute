# Copy this file to .env and fill in real values.
# .env is gitignored — NEVER commit secrets.

# ─── Environment ─────────────────────────────────────────────────────────────
# development → OTP returned in response (dev_otp), docs enabled
# production  → OTP via MSG91, docs disabled, strict security
#ENV=production
ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL (Supabase / any PG host):
DATABASE_URL=postgresql+psycopg2://<user>:<password>@<host>:5432/<dbname>
# Local dev SQLite fallback:
# DATABASE_URL=sqlite:///./mediroute.db

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_SECURE_RANDOM_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated — no trailing spaces
ALLOWED_ORIGINS=https://your-frontend-domain.com,capacitor://localhost,https://localhost

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_PHONE=10_DIGIT_PHONE
ADMIN_SECRET=REPLACE_WITH_SECURE_ADMIN_SECRET

# ─── MSG91 OTP (required for ENV=production) ─────────────────────────────────
#MSG91_AUTH_KEY=your_msg91_auth_key
#MSG91_TEMPLATE_ID=your_dlt_approved_template_id
# MSG91_SENDER_ID=MEDIRT

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# ─── Firebase FCM (push notifications) ──────────────────────────────────────
# Paste the FULL JSON content of your Firebase service account key (single line).
# Generate: Firebase Console → Project Settings → Service Accounts → Generate new private key
# In Render: paste the JSON value directly into the env var (not a file path).
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# ─── Sentry (optional — error monitoring) ────────────────────────────────────
# SENTRY_DSN=https://your-dsn@sentry.io/project-id

# ─── Optional overrides ──────────────────────────────────────────────────────
# OTP_RATE_LIMIT_MAX=3
# OTP_RATE_LIMIT_WINDOW_SEC=300
# PDF_DIR=generated_pdfs
# UPLOAD_DIR=uploads/resumes
